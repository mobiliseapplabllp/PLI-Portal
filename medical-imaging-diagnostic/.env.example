# Copy to .env and adjust for your deployment.

# --- Security ---
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- Database ---
# Dev default is a local SQLite file. For production use Postgres:
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/mid
DATABASE_URL=sqlite:///./mid.db

# --- AI engines ---
# mock  -> deterministic heuristic inference, runs anywhere (default)
# real  -> use pretrained models from requirements-ml.txt (needs torch)
# monai -> real CT/MRI via the MONAI Label service (see monai/README.md)
AI_ENGINE_MODE=mock

# --- Holistic AI (patient AI Assistant) ---
# Command used to invoke the Claude CLI for whole-profile reasoning + chat.
# Must be on PATH. If unavailable, the app falls back to a deterministic rules
# engine (assessment still works; chat is disabled).
CLAUDE_CLI_CMD=claude

# --- Uploads ---
UPLOAD_DIR=./uploads
